/// Firma başına tek Paraşüt (muhasebe SaaS) OAuth2 bağlantısı — clientSecret ve
/// token'lar sunucu tarafında AES-256-GCM ile şifreli tutulur (bkz. src/lib/crypto.ts),
/// tarayıcıya asla düz metin olarak gönderilmez.
model ParasutIntegration {
  id      String @id @default(uuid())
  ownerId String @unique
  owner   User   @relation(fields: [ownerId], references: [id], onDelete: Cascade)

  clientId        String
  clientSecretEnc String

  accessTokenEnc  String?
  refreshTokenEnc String?
  tokenExpiresAt  DateTime?

  parasutCompanyId   String?
  parasutCompanyName String?

  connectedAt    DateTime?
  lastSyncAt     DateTime?
  lastSyncStatus String?
  lastSyncCount  Int       @default(0)

  @@map("parasut_integrations")
}

/// Şirket düzeyinde (müşteri/servis emrine bağlı olmayan) genel belgeler —
/// ruhsat, sigorta poliçesi, sözleşme şablonu vb. Entegrasyonlar'daki ServiceOrder
/// sözleşme eki ile aynı desen: dosya base64 data URL olarak saklanır.
model Document {
  id      String @id @default(uuid())
  ownerId String
  owner   User   @relation(fields: [ownerId], references: [id], onDelete: Cascade)

  name         String
  fileDataUrl  String @db.Text
  fileName     String
  fileSizeKb   Int    @default(0)

  createdAt DateTime @default(now())

  @@index([ownerId])
  @@map("documents")
}

/// Google Calendar entegrasyonu — PestShield TEK bir paylaşımlı Google OAuth
/// uygulaması olarak kayıtlıdır (GOOGLE_OAUTH_CLIENT_ID/SECRET ortam
/// değişkenleri), Paraşüt'ten farklı olarak kiracı başına client id/secret YOK.
/// Her kiracı sadece "Google ile Bağlan" der, kendi access/refresh token'ı
/// burada (şifreli) saklanır.
model GoogleCalendarIntegration {
  id      String @id @default(uuid())
  ownerId String @unique
  owner   User   @relation(fields: [ownerId], references: [id], onDelete: Cascade)

  accessTokenEnc  String?
  refreshTokenEnc String?
  tokenExpiresAt  DateTime?

  calendarId   String  @default("primary")
  calendarName String?

  connectedAt    DateTime?
  lastSyncAt     DateTime?
  lastSyncStatus String?
  lastSyncCount  Int       @default(0)

  @@map("google_calendar_integrations")
}

/// PestShield tarafından üretilip yeni müşteri firmalara iletilen katılım kodu.
/// Tam Company/tenant modeli sonraki bir sprintte eklenecek.
model CompanyCode {
  id          String    @id @default(uuid())
  code        String    @unique
  companyName String
  maxUses     Int       @default(1)
  usedCount   Int       @default(0)
  expiresAt   DateTime?
  createdAt   DateTime  @default(now())

  @@map("company_codes")
}
